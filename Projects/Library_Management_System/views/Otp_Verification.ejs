<!DOCTYPE html>
<html lang="en">
<head>

   <%- include('./partials/Head') %>

   <title>OTP Verification</title>

   <style>

      body{
         background:#f7f1f3;
         font-family:'Poppins',sans-serif;
      }

      .otp-container{
         min-height:100vh;
         display:flex;
         justify-content:center;
         align-items:center;
         padding:30px;
      }

      .otp-card{
         width:100%;
         max-width:1000px;
         background:white;
         border-radius:30px;
         overflow:hidden;
         box-shadow:0 15px 40px rgba(0,0,0,0.08);
      }

      .left-panel{
         background:linear-gradient(135deg,#7b1e3a,#a8325c);
         color:white;
         padding:60px;
         height:100%;
         display:flex;
         flex-direction:column;
         justify-content:center;
      }

      .left-panel h1{
         font-size:48px;
         font-weight:700;
         line-height:65px;
         margin-bottom:20px;
      }

      .left-panel p{
         color:#f5d6df;
         line-height:30px;
      }

      .quote-box{
         margin-top:35px;
         background:rgba(255,255,255,0.1);
         padding:20px;
         border-radius:16px;
      }

      .right-panel{
         padding:70px 50px;
         display:flex;
         align-items:center;
         justify-content:center;
         background:white;
      }

      .otp-form{
         width:100%;
         max-width:400px;
      }

      .otp-form h2{
         color:#7b1e3a;
         font-weight:700;
         margin-bottom:10px;
      }

      .otp-form p{
         color:gray;
         margin-bottom:35px;
         line-height:28px;
      }

      .otp-inputs{
         display:flex;
         gap:12px;
         justify-content:center;
         margin-bottom:30px;
      }

      .otp-inputs input{
         width:55px;
         height:60px;
         border:1px solid #ddd;
         border-radius:14px;
         text-align:center;
         font-size:24px;
         font-weight:600;
         outline:none;
         transition:0.3s;
      }

      .otp-inputs input:focus{
         border-color:#7b1e3a;
         box-shadow:0 0 0 3px rgba(123,30,58,0.15);
      }

      .verify-btn{
         width:100%;
         height:52px;
         border:none;
         border-radius:14px;
         background:#7b1e3a;
         color:white;
         font-size:16px;
         font-weight:600;
         transition:0.3s;
      }

      .verify-btn:hover{
         background:#5d152c;
      }

      .resend{
         text-align:center;
         margin-top:20px;
         color:gray;
      }

      .resend a{
         color:#7b1e3a;
         text-decoration:none;
         font-weight:600;
      }

      @media(max-width:991px){

         .left-panel{
            padding:40px;
         }

         .left-panel h1{
            font-size:36px;
            line-height:50px;
         }

         .right-panel{
            padding:40px 25px;
         }
      }

      @media(max-width:576px){

         .otp-inputs{
            gap:8px;
         }

         .otp-inputs input{
            width:45px;
            height:55px;
            font-size:20px;
         }

         .left-panel h1{
            font-size:30px;
            line-height:42px;
         }
      }

   </style>

</head>

<body>

   <%- include('./partials/Nav') %>

   <div class="container otp-container">

      <div class="otp-card">

         <div class="row g-0">

            <!-- LEFT PANEL -->

            <div class="col-lg-6">

               <div class="left-panel">

                  <h1>
                     Verify Your <br>
                     Account 📚
                  </h1>

                  <p>
                     Secure your library account with email verification
                     and continue your reading journey seamlessly.
                  </p>

                  <div class="quote-box">

                     <h5>📖 Daily Quote</h5>

                     <p class="mb-0">
                        “Books are uniquely portable magic.”
                     </p>

                  </div>

               </div>

            </div>

            <!-- RIGHT PANEL -->

            <div class="col-lg-6">

               <div class="right-panel">

                  <div class="otp-form">

                     <h2>OTP Verification</h2>

                     <p>
                        Enter the 6-digit OTP sent to your registered email.
                     </p>

                     <!-- BACKEND API CALL -->

                     <form action="/auth/api/verify-otp" method="POST">

                        <div class="otp-inputs">

                           <input type="text" maxlength="1" name="otp1" required>
                           <input type="text" maxlength="1" name="otp2" required>
                           <input type="text" maxlength="1" name="otp3" required>
                           <input type="text" maxlength="1" name="otp4" required>
                           <input type="text" maxlength="1" name="otp5" required>
                           <input type="text" maxlength="1" name="otp6" required>

                        </div>

                        <button type="submit" class="verify-btn">
                           Verify OTP
                        </button>

                     </form>

                     <div class="resend">

                        Didn't receive OTP?
                        <a href="/resend-otp">
                           Resend OTP
                        </a>

                     </div>

                  </div>

               </div>

            </div>

         </div>

      </div>

   </div>

   <%- include('./partials/Scripts') %>

   <script>

      const inputs = document.querySelectorAll(".otp-inputs input");

      inputs.forEach((input, index) => {

         input.addEventListener("keyup", (e) => {

            if(input.value.length === 1){

               if(index < inputs.length - 1){
                  inputs[index + 1].focus();
               }

            }

            if(e.key === "Backspace"){

               if(index > 0 && input.value === ""){
                  inputs[index - 1].focus();
               }

            }

         });

      });

   </script>

</body>
</html>

