<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Blog Home</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f5f5f5;
            color: #333;
            margin-top: 70px;
        }

        /* Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Header/Hero Section */
        .page-header {
            text-align: center;
            margin-bottom: 40px;
            padding: 40px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 16px;
            color: white;
        }

        .page-header h1 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: -0.5px;
        }

        .page-header p {
            font-size: 18px;
            opacity: 0.95;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Search Section */
        .search-section {
            margin-bottom: 40px;
            text-align: center;
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .search-section h2 {
            font-size: 24px;
            margin-bottom: 20px;
            color: #333;
        }

        .search-box {
            max-width: 600px;
            margin: 0 auto;
            display: flex;
            gap: 10px;
        }

        .search-box input {
            flex: 1;
            padding: 12px 20px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 16px;
            outline: none;
            transition: all 0.3s;
        }

        .search-box input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
        }

        .search-box button {
            padding: 12px 24px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            transition: background 0.3s;
        }

        .search-box button:hover {
            background: #5a67d8;
        }

        .reset-btn {
            background: #6c757d !important;
        }

        .reset-btn:hover {
            background: #5a6268 !important;
        }

        .search-info {
            margin-top: 15px;
            color: #666;
            font-size: 14px;
            font-weight: 500;
        }

        /* Blog Grid - 3 cards per row */
        .blog-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-top: 20px;
        }

        /* Card Design */
        .card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.12);
        }

        /* Card Image Cap */
        .card-img-top {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background-color: #f0f0f0;
        }

        /* Card Body */
        .card-body {
            padding: 20px;
        }

        /* Card Title */
        .card-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #333;
            line-height: 1.3;
        }

        /* Card Text */
        .card-text {
            font-size: 14px;
            color: #666;
            line-height: 1.5;
            margin-bottom: 20px;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* Button */
        .btn {
            display: inline-block;
            background: #667eea;
            color: white;
            padding: 8px 20px;
            border-radius: 6px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: background 0.2s;
        }

        .btn:hover {
            background: #5a67d8;
        }

        /* No results message */
        .no-results {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 12px;
            grid-column: 1 / -1;
        }

        .no-results h3 {
            font-size: 24px;
            margin-bottom: 10px;
            color: #333;
        }

        .no-results p {
            color: #666;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .blog-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 25px;
            }
        }

        @media (max-width: 768px) {
            .page-header h1 {
                font-size: 32px;
            }
            .blog-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .search-box {
                flex-direction: column;
            }
            .container {
                padding: 20px;
            }
            .search-section {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <%- include('./partials/Nav') %>

    <div class="container">
        <!-- Page Header / Heading -->
        <div class="page-header">
            <h1>📝 Welcome to Our Blog</h1>
            <p>Discover amazing stories, insights, and knowledge from our community</p>
        </div>

        <!-- Search Section -->
        <div class="search-section">
            <h2>🔍 Find Your Next Read</h2>
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="Search by title..." autocomplete="off">
                <button onclick="searchBlogs()">Search</button>
                <button onclick="resetSearch()" class="reset-btn">Reset</button>
            </div>
            <div class="search-info" id="searchInfo"></div>
        </div>

        <!-- Blog Grid -->
        <div class="blog-grid" id="blogGrid">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <div class="card" data-title="<%= blog.title.toLowerCase() %>">
                        <img src="<%= blog.coverImageURL || 'https://via.placeholder.com/300x200?text=No+Image' %>" 
                             class="card-img-top" 
                             alt="<%= blog.title %>"
                             onerror="this.src='https://via.placeholder.com/300x200?text=Image+Not+Found'">
                        <div class="card-body">
                            <h5 class="card-title"><%= blog.title %></h5>
                            
                            <a href="/blog/<%= blog._id %>" class="btn">Read</a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="no-results">
                    <h3>No blogs found</h3>
                    <p>Check back later for new content!</p>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        // Store all cards for searching
        const allCards = document.querySelectorAll('.card');
        const searchInfo = document.getElementById('searchInfo');
        const searchInput = document.getElementById('searchInput');

        function searchBlogs() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            
            let visibleCount = 0;
            
            allCards.forEach(card => {
                const title = card.getAttribute('data-title');
                
                if (searchTerm === '') {
                    // Show all cards if search is empty
                    card.style.display = '';
                    visibleCount = allCards.length;
                } else if (title.includes(searchTerm)) {
                    // Show matching cards
                    card.style.display = '';
                    visibleCount++;
                } else {
                    // Hide non-matching cards
                    card.style.display = 'none';
                }
            });
            
            // Update search info message
            if (searchTerm === '') {
                searchInfo.textContent = `✨ Showing all ${visibleCount} blog${visibleCount !== 1 ? 's' : ''}`;
            } else {
                searchInfo.textContent = `🔎 Found ${visibleCount} result${visibleCount !== 1 ? 's' : ''} for "${searchTerm}"`;
            }
        }
        
        function resetSearch() {
            // Clear the search input
            searchInput.value = '';
            
            // Show all cards
            allCards.forEach(card => {
                card.style.display = '';
            });
            
            // Update search info
            searchInfo.textContent = `✨ Showing all ${allCards.length} blog${allCards.length !== 1 ? 's' : ''}`;
        }
        
        // Add enter key support
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    searchBlogs();
                }
            });
        }
        
        // Initialize search info on page load
        if (allCards.length > 0) {
            searchInfo.textContent = `✨ Showing all ${allCards.length} blog${allCards.length !== 1 ? 's' : ''}`;
        }
    </script>

    <%- include('./partials/scripts') %>
</body>
</html>


