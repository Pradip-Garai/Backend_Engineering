<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/Head') %>
    <title>Admin Dashboard - LibFlow</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        /* ─── MODERN SYSTEM COLOR PALETTE ─────────────────────── */
        :root {
            --bg-base: #f8fafc;
            --sidebar-bg: #0f172a; /* Sleek high-end Slate-900 */
            --sidebar-hover: #1e293b;
            --card-bg: #ffffff;
            --accent-wine: #7b1e3a; /* LibFlow signature maroon */
            --accent-wine-light: #9c284e;
            --accent-wine-trans: rgba(123, 30, 58, 0.08);
            --border-subtle: #f1f5f9;
            --border-main: #e2e8f0;
            --text-title: #0f172a;
            --text-body: #334155;
            --text-muted: #64748b;
            
            --shadow-subtle: 0 4px 20px -2px rgba(15, 23, 42, 0.04);
            --shadow-hover: 0 20px 25px -5px rgba(15, 23, 42, 0.08), 0 10px 10px -5px rgba(15, 23, 42, 0.03);
            --shadow-sidebar: 4px 0 24px rgba(15, 23, 42, 0.05);
            
            --radius-card: 20px;
            --radius-btn: 12px;
            --radius-input: 12px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-base);
            color: var(--text-body);
            font-family: 'Poppins', 'Inter', sans-serif;
            overflow: hidden;
            display: flex;
            height: 100vh;
        }

        /* ─── SIDEBAR WRAPPER (High-End SaaS Feel) ───────────── */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            padding: 30px 18px;
            height: 100%;
            position: relative;
            z-index: 100;
            flex-shrink: 0;
            box-shadow: var(--shadow-sidebar);
            overflow-y: hidden;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            margin-bottom: 45px;
            padding: 0 10px;
        }

        .sidebar-logo {
            height: 44px;
            width: auto;
            object-fit: contain;
            filter: brightness(1.1);
        }

        .sidebar-menu {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px;
            flex-grow: 1;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            border-radius: var(--radius-btn);
            color: #94a3b8;
            font-size: 14.5px;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .menu-item svg {
            width: 20px;
            height: 20px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .menu-item:hover {
            background-color: var(--sidebar-hover);
            color: #f1f5f9;
        }

        .menu-item.active {
            background: linear-gradient(135deg, var(--accent-wine) 0%, var(--accent-wine-light) 100%);
            color: #ffffff;
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(123, 30, 58, 0.3);
        }

        .sidebar-footer {
            border-top: 1px solid #1e293b;
            padding-top: 20px;
            margin-top: auto;
        }

        .btn-exit {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #fca5a5;
            text-decoration: none;
            font-size: 14.5px;
            font-weight: 500;
            border-radius: var(--radius-btn);
            transition: all 0.2s ease;
        }

        .btn-exit svg {
            width: 18px;
            height: 18px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
        }

        .btn-exit:hover {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

        /* ─── MAIN CONTENT VIEWPORT ─────────────────────────── */
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow-y: auto;
            background-color: var(--bg-base);
        }

        /* Dashboard Header */
        .dashboard-header {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border-main);
            padding: 22px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 90;
        }

        .header-title h2 {
            font-size: 23px;
            font-weight: 700;
            color: var(--text-title);
            letter-spacing: -0.5px;
        }

        .header-title p {
            font-size: 13.5px;
            color: var(--text-muted);
            margin-top: 3px;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        /* Notification Icon */
        .btn-notify {
            position: relative;
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            transition: color 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-notify:hover {
            color: var(--accent-wine);
        }

        .btn-notify svg {
            width: 22px;
            height: 22px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
        }

        .btn-notify::after {
            content: '';
            position: absolute;
            top: -2px;
            right: 0px;
            width: 8px;
            height: 8px;
            background-color: #ef4444;
            border-radius: 50%;
            border: 2px solid #ffffff;
        }

        .admin-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-left: 20px;
            border-left: 1px solid var(--border-main);
        }

        .admin-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent-wine) 0%, var(--accent-wine-light) 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 15px;
            box-shadow: 0 4px 10px rgba(123, 30, 58, 0.12);
        }

        .admin-name {
            font-weight: 600;
            font-size: 14.5px;
            color: var(--text-title);
        }

        /* Dashboard Main Body */
        .dashboard-body {
            padding: 40px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }

        /* ─── METRIC STATS CARDS ───────────────────────────── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--card-bg);
            border-radius: var(--radius-card);
            padding: 24px;
            box-shadow: var(--shadow-subtle);
            border: 1px solid var(--border-main);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: transparent;
            transition: background 0.3s;
        }

        .stat-card:hover::before {
            background: var(--accent-wine);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
        }

        .stat-info h3 {
            font-size: 30px;
            font-weight: 800;
            color: var(--text-title);
            margin-bottom: 4px;
            letter-spacing: -1px;
        }

        .stat-info p {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.3s;
        }

        .stat-card:hover .stat-icon {
            transform: scale(1.1);
        }

        .stat-icon.books { background: rgba(99, 102, 241, 0.08); color: #6366f1; }
        .stat-icon.borrowed { background: rgba(20, 184, 166, 0.08); color: #14b8a6; }
        .stat-icon.readers { background: rgba(245, 158, 11, 0.08); color: #f59e0b; }
        .stat-icon.overdue { background: rgba(239, 68, 68, 0.08); color: #ef4444; }

        .stat-icon svg {
            width: 22px;
            height: 22px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.2;
        }

        /* ─── TABBED CONTAINER VIEWS ───────────────────────── */
        .tab-panel {
            display: none;
            animation: panelFadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .tab-panel.active {
            display: block;
        }

        @keyframes panelFadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .panel-card {
            background: var(--card-bg);
            border-radius: var(--radius-card);
            box-shadow: var(--shadow-subtle);
            border: 1px solid var(--border-main);
            padding: 35px;
            margin-bottom: 30px;
        }

        .panel-title {
            font-size: 17px;
            font-weight: 700;
            color: var(--text-title);
            margin-bottom: 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .panel-title-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .panel-title-left svg {
            width: 20px;
            height: 20px;
            fill: none;
            stroke: var(--accent-wine);
            stroke-width: 2.2;
        }

        /* ─── TAB 1: DASHBOARD OVERVIEW ─────────────────────── */
        .overview-grid {
            display: grid;
            grid-template-columns: 2fr 1.1fr;
            gap: 30px;
        }

        /* Activity Logs */
        .activity-feed {
            display: flex;
            flex-direction: column;
        }

        .activity-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid var(--border-subtle);
        }

        .activity-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .activity-details {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .activity-badge {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            background-color: var(--bg-base);
            border: 1px solid var(--border-main);
        }

        .activity-text h4 {
            font-size: 14.5px;
            font-weight: 700;
            color: var(--text-title);
        }

        .activity-text p {
            font-size: 12.5px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .activity-time {
            font-size: 12.5px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Platform Health Section */
        .health-dot {
            width: 8px;
            height: 8px;
            background-color: #10b981;
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 8px #10b981;
            animation: pulseDot 2s infinite;
        }

        @keyframes pulseDot {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }

        .health-desc {
            font-size: 14px;
            line-height: 1.7;
            color: var(--text-body);
            margin-bottom: 25px;
        }

        .capacity-widget {
            background: var(--bg-base);
            border-radius: 16px;
            padding: 20px;
            border: 1px solid var(--border-main);
        }

        .capacity-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-title);
        }

        .progress-bar-wrap {
            width: 100%;
            height: 10px;
            background: var(--border-main);
            border-radius: 6px;
            overflow: hidden;
        }

        .progress-bar-fill {
            width: 12.4%;
            height: 100%;
            background: linear-gradient(90deg, var(--accent-wine) 0%, var(--accent-wine-light) 100%);
            border-radius: 6px;
        }

        /* ─── TAB 2: INTAKE BOOK FORM ──────────────────────── */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }

        .form-group {
            margin-bottom: 22px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group.full-width {
            grid-column: span 2;
        }

        .form-group label {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text-title);
        }

        .form-control, .form-select {
            width: 100%;
            padding: 13px 16px;
            border-radius: var(--radius-input);
            border: 1.5px solid var(--border-main);
            background: var(--bg-base);
            color: var(--text-body);
            font-family: inherit;
            font-size: 14px;
            outline: none;
            transition: all 0.2s ease;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--accent-wine);
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(123, 30, 58, 0.08);
        }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 15px;
            border-top: 1px solid var(--border-subtle);
            padding-top: 25px;
        }

        .btn-submit {
            padding: 13px 32px;
            border-radius: var(--radius-input);
            border: none;
            background: linear-gradient(135deg, var(--accent-wine) 0%, var(--accent-wine-light) 100%);
            color: white;
            font-weight: 600;
            font-size: 14.5px;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 4px 15px rgba(123, 30, 58, 0.2);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(123, 30, 58, 0.3);
        }

        .btn-reset {
            padding: 13px 32px;
            border-radius: var(--radius-input);
            border: 1px solid var(--border-main);
            background: #ffffff;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 14.5px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-reset:hover {
            background: var(--bg-base);
            color: var(--text-title);
        }

        /* ─── TAB 3: MANAGE BOOKS DATATABLE ────────────────── */
        .table-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            gap: 20px;
        }

        .search-box-wrapper {
            position: relative;
            max-width: 400px;
            width: 100%;
        }

        .search-box-wrapper svg {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            color: var(--text-muted);
            stroke: currentColor;
            fill: none;
            stroke-width: 2.2;
        }

        .search-input {
            width: 100%;
            padding: 13px 16px 13px 48px;
            border-radius: var(--radius-input);
            border: 1.5px solid var(--border-main);
            background: var(--bg-base);
            outline: none;
            font-size: 14px;
            transition: all 0.2s ease;
        }

        .search-input:focus {
            border-color: var(--accent-wine);
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(123, 30, 58, 0.08);
        }

        .custom-table-container {
            width: 100%;
            overflow-x: auto;
            border-radius: 16px;
            border: 1px solid var(--border-main);
        }

        .custom-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .custom-table th {
            background: var(--bg-base);
            padding: 18px 24px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            border-bottom: 1.5px solid var(--border-main);
        }

        .custom-table td {
            padding: 20px 24px;
            border-bottom: 1px solid var(--border-subtle);
            font-size: 14px;
            color: var(--text-body);
            vertical-align: middle;
        }

        .custom-table tr:last-child td {
            border-bottom: none;
        }

        .custom-table tr:hover td {
            background-color: #fafbfc;
        }

        .book-meta {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .book-cover {
            width: 42px;
            height: 56px;
            border-radius: 8px;
            background: var(--bg-base);
            object-fit: cover;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            border: 1px solid var(--border-main);
        }

        .book-details h4 {
            font-size: 14.5px;
            font-weight: 700;
            color: var(--text-title);
        }

        .book-details p {
            font-size: 12.5px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .badge-cat {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
        }

        /* Action Buttons */
        .action-btns {
            display: flex;
            gap: 8px;
        }

        .btn-action {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1.5px solid var(--border-main);
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-action svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.2;
        }

        .btn-action.view:hover {
            background: rgba(99, 102, 241, 0.08);
            color: #6366f1;
            border-color: rgba(99, 102, 241, 0.2);
        }

        .btn-action.delete:hover {
            background: rgba(239, 68, 68, 0.08);
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.2);
        }

        /* ─── GLASSMODAL DIALOG OVERLAYS ────────────────────── */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(5px);
            z-index: 1000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal-card {
            background: var(--card-bg);
            border-radius: var(--radius-card);
            max-width: 500px;
            width: 100%;
            padding: 35px;
            box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.25);
            animation: modalSlideIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            border: 1px solid var(--border-main);
        }

        @keyframes modalSlideIn {
            from { transform: scale(0.95) translateY(15px); opacity: 0; }
            to { transform: scale(1) translateY(0); opacity: 1; }
        }

        .modal-header-section {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }

        .modal-icon-wrap {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            background: rgba(239, 68, 68, 0.08);
            color: #ef4444;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-icon-wrap svg {
            width: 22px;
            height: 22px;
            stroke: currentColor;
            fill: none;
            stroke-width: 2.2;
        }

        .modal-header-section h3 {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-title);
        }

        .modal-body-section p {
            color: var(--text-body);
            font-size: 14.5px;
            line-height: 1.6;
            margin-bottom: 25px;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            border-top: 1px solid var(--border-subtle);
            padding-top: 20px;
        }

        .btn-confirm-delete {
            background: #ef4444;
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: var(--radius-input);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-confirm-delete:hover {
            background: #dc2626;
        }

        /* ─── RESPONSIVENESS ────────────────────────────── */
        @media (max-width: 1024px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .overview-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            body {
                flex-direction: column;
                overflow-y: auto;
            }
            .sidebar {
                width: 100%;
                height: auto;
                padding: 15px;
            }
            .sidebar-brand {
                margin-bottom: 20px;
            }
            .sidebar-menu {
                flex-direction: row;
                overflow-x: auto;
                gap: 5px;
                padding-bottom: 10px;
            }
            .menu-item {
                white-space: nowrap;
                padding: 10px 15px;
            }
            .sidebar-footer {
                display: none;
            }
            .main-content {
                height: auto;
                overflow-y: visible;
            }
            .dashboard-header {
                padding: 15px 20px;
            }
            .dashboard-body {
                padding: 20px;
            }
            .form-grid {
                grid-template-columns: 1fr;
            }
            .form-group.full-width {
                grid-column: span 1;
            }
        }

        /* ─── UPLOAD DROP ZONE STYLES ───────────────────────── */
        .upload-drop-zone {
            border: 2px dashed var(--border-main);
            border-radius: var(--radius-input);
            padding: 30px 20px;
            text-align: center;
            background: var(--bg-base);
            cursor: pointer;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            min-height: 180px;
        }

        .upload-drop-zone:hover, .upload-drop-zone.dragover {
            border-color: var(--accent-wine);
            background: rgba(123, 30, 58, 0.01);
        }

        .upload-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(123, 30, 58, 0.06);
            color: var(--accent-wine);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.25s ease;
        }

        .upload-drop-zone:hover .upload-icon {
            transform: translateY(-4px);
        }

        .upload-icon svg {
            width: 22px;
            height: 22px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.2;
        }

        .upload-text {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text-title);
        }

        .upload-text span {
            color: var(--accent-wine);
            text-decoration: underline;
        }

        .upload-subtext {
            font-size: 11.5px;
            color: var(--text-muted);
        }

        /* Upload Image Preview Frame */
        .upload-preview {
            position: absolute;
            inset: 0;
            background: #ffffff;
            border-radius: var(--radius-input);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 12px;
            z-index: 10;
        }

        .upload-preview img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            border-radius: 8px;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
        }

        .btn-remove-preview {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(15, 23, 42, 0.75);
            color: white;
            border: none;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
            z-index: 20;
            line-height: 1;
        }

        .btn-remove-preview:hover {
            background: rgba(239, 68, 68, 0.9);
        }
    </style>
</head>
