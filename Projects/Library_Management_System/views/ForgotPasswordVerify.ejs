<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/Head') %>
    <title>Verify Recovery Code - Library Management System</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            background: #fcf8f9;
            font-family: 'Poppins', sans-serif;
        }

        .otp-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            min-height: 0;
        }

        .otp-card {
            width: 100%;
            max-width: 1000px;
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(123, 30, 58, 0.06);
            display: flex;
            height: 520px;
        }

        .row-container {
            display: flex;
            width: 100%;
            height: 100%;
        }

        .left-panel {
            flex: 1;
            background: linear-gradient(135deg, rgba(123, 30, 58, 0.8), rgba(168, 50, 92, 0.8)), url('/resgiter.jpg') no-repeat center center;
            background-size: cover;
            color: white;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .left-panel h1 {
            font-size: 40px;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 15px;
        }

        .left-panel p {
            color: rgba(255, 255, 255, 0.85);
            line-height: 1.7;
            font-size: 15px;
        }

        .right-panel {
            flex: 1;
            padding: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-y: auto;
        }

        .otp-content {
            width: 100%;
            max-width: 380px;
        }

        .otp-content h2 {
            color: #7b1e3a;
            font-weight: 700;
            margin-bottom: 8px;
            font-size: 28px;
        }

        .otp-content p {
            color: #888;
            margin-bottom: 30px;
            font-size: 14px;
            line-height: 1.6;
        }

        .error-message {
            color: #dc3545;
            font-size: 13px;
            margin-bottom: 20px;
            padding: 12px 15px;
            background: #f8d7da;
            border-radius: 8px;
            border-left: 4px solid #dc3545;
        }

        .otp-inputs {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 30px;
        }

        .otp-input {
            width: 100%;
            max-width: 50px;
            height: 60px;
            text-align: center;
            font-size: 24px;
            font-weight: 700;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            transition: 0.3s;
            color: #7b1e3a;
        }

        .otp-input:focus {
            outline: none;
            border-color: #7b1e3a;
            box-shadow: 0 0 0 3px rgba(123, 30, 58, 0.1);
        }

        .otp-input.filled {
            border-color: #7b1e3a;
            background: rgba(123, 30, 58, 0.03);
        }

        .verify-btn {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #7b1e3a, #a8325c);
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .verify-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(123, 30, 58, 0.3);
        }

        .verify-btn:active {
            transform: translateY(0);
        }

        .resend-link {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #888;
        }

        .resend-link a {
            color: #7b1e3a;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
        }

        .resend-link a:hover {
            text-decoration: underline;
        }

        @media (max-width: 991px) {
            html, body {
                height: auto;
                overflow: auto;
            }

            .otp-container {
                height: auto;
                padding: 30px 15px;
            }

            .otp-card {
                height: auto;
                border-radius: 20px;
                flex-direction: column;
            }

            .left-panel {
                padding: 40px;
            }

            .left-panel h1 {
                font-size: 32px;
            }

            .right-panel {
                height: auto;
                padding: 40px 25px;
            }

            .otp-inputs {
                gap: 8px;
            }

            .otp-input {
                max-width: 45px;
                height: 50px;
                font-size: 20px;
            }
        }

        @media (max-width: 576px) {
            .otp-container {
                padding: 15px;
            }

            .left-panel {
                padding: 30px;
                text-align: center;
            }

            .left-panel h1 {
                font-size: 24px;
                line-height: 1.3;
            }

            .left-panel p {
                font-size: 13px;
            }

            .right-panel {
                padding: 30px 20px;
            }

            .otp-content h2 {
                font-size: 22px;
            }

            .otp-content p {
                font-size: 13px;
            }

            .otp-inputs {
                gap: 6px;
            }

            .otp-input {
                max-width: 40px;
                height: 45px;
                font-size: 18px;
            }
        }
    </style>
</head>

<body>
    <%- include('./partials/Nav') %>

    <div class="otp-container">
        <div class="otp-card">
            <div class="row-container">
                <!-- LEFT PANEL -->
                <div class="left-panel">
                    <h1>Verify Your Email 🔐</h1>
                    <p>
                        We've sent a 6-digit verification code to your registered email address. Please enter it below to verify your identity and proceed with password reset.
                    </p>
                </div>

                <!-- RIGHT PANEL -->
                <div class="right-panel">
                    <div class="otp-content">
                        <h2>Enter Code</h2>
                        <p>
                            Enter the 6-digit code sent to <strong><%= email %></strong>
                        </p>

                        <% if (locals.error) { %>
                            <div class="error-message">
                                <%= error %>
                            </div>
                        <% } %>

                        <form action="/auth/api/forgot-password-verify" method="POST">
                            <input type="hidden" name="email" value="<%= email %>" />
                            
                            <div class="otp-inputs">
                                <input 
                                    type="number" 
                                    class="otp-input" 
                                    name="otp1" 
                                    max="9" 
                                    inputmode="numeric"
                                    required
                                    onInput="this.value = this.value.slice(0,1); if(this.value) document.querySelector('input[name=otp2]').focus()">
                                <input 
                                    type="number" 
                                    class="otp-input" 
                                    name="otp2" 
                                    max="9" 
                                    inputmode="numeric"
                                    required
                                    onInput="this.value = this.value.slice(0,1); if(this.value) document.querySelector('input[name=otp3]').focus()">
                                <input 
                                    type="number" 
                                    class="otp-input" 
                                    name="otp3" 
                                    max="9" 
                                    inputmode="numeric"
                                    required
                                    onInput="this.value = this.value.slice(0,1); if(this.value) document.querySelector('input[name=otp4]').focus()">
                                <input 
                                    type="number" 
                                    class="otp-input" 
                                    name="otp4" 
                                    max="9" 
                                    inputmode="numeric"
                                    required
                                    onInput="this.value = this.value.slice(0,1); if(this.value) document.querySelector('input[name=otp5]').focus()">
                                <input 
                                    type="number" 
                                    class="otp-input" 
                                    name="otp5" 
                                    max="9" 
                                    inputmode="numeric"
                                    required
                                    onInput="this.value = this.value.slice(0,1); if(this.value) document.querySelector('input[name=otp6]').focus()">
                                <input 
                                    type="number" 
                                    class="otp-input" 
                                    name="otp6" 
                                    max="9" 
                                    inputmode="numeric"
                                    required
                                    onInput="this.value = this.value.slice(0,1)">
                            </div>

                            <button type="submit" class="verify-btn">
                                Verify Code
                            </button>
                        </form>

                        <div class="resend-link">
                            Didn't receive a code? <a href="/auth/api/forgot-password">Request again</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('./partials/Scripts') %>
</body>
</html>