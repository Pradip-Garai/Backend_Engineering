<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/Head') %>
    <title>OTP Verification - LibFlow</title>

    <style>
        /* ─── BASE RESET & LAYOUT ────────────────────────────── */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            background: #fcf8f9;
            font-family: 'Poppins', sans-serif;
        }

        .otp-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            min-height: 0;
        }

        .otp-card {
            width: 100%;
            max-width: 1000px;
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(123, 30, 58, 0.06);
            display: flex;
            height: 520px; /* fixed professional height */
        }

        .row-container {
            display: flex;
            width: 100%;
            height: 100%;
        }

        /* ─── LEFT PANEL (Branding) ─────────────────────────── */
        .left-panel {
            width: 50%;
            background: linear-gradient(135deg, #7b1e3a 0%, #9c284e 50%, #b83a64 100%);
            color: white;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 100%;
            position: relative;
            overflow: hidden;
        }

        /* Elegant design shape */
        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -50px;
            left: -50px;
            width: 200px;
            height: 200px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50%;
            pointer-events: none;
        }

        .left-panel-content h1 {
            font-size: 42px;
            font-weight: 700;
            line-height: 1.25;
            margin-bottom: 20px;
            letter-spacing: -0.5px;
        }

        .left-panel-content p {
            color: #fce7ec;
            line-height: 1.7;
            font-size: 15px;
            font-weight: 300;
        }

        .quote-box {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.12);
            padding: 22px;
            border-radius: 20px;
            backdrop-filter: blur(8px);
        }

        .quote-box h5 {
            font-size: 13.5px;
            font-weight: 600;
            color: #ffb8cd;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .quote-box p {
            font-size: 14.5px;
            line-height: 1.6;
            color: #ffffff;
            font-style: italic;
            margin: 0;
        }

        /* ─── RIGHT PANEL (Verification Form) ───────────────── */
        .right-panel {
            width: 50%;
            padding: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #ffffff;
            height: 100%;
        }

        .otp-form {
            width: 100%;
            max-width: 380px;
        }

        .otp-form h2 {
            color: #7b1e3a;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }

        .otp-form p {
            color: #64748b;
            font-size: 14.5px;
            margin-bottom: 35px;
            line-height: 1.6;
        }

        /* OTP Input Boxes */
        .otp-inputs {
            display: flex;
            gap: 12px;
            justify-content: space-between;
            margin-bottom: 30px;
        }

        .otp-inputs input {
            width: 50px;
            height: 56px;
            border: 2px solid #e2e8f0;
            border-radius: 14px;
            text-align: center;
            font-size: 22px;
            font-weight: 600;
            color: #1e293b;
            outline: none;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            background: #f8fafc;
        }

        .otp-inputs input:focus {
            border-color: #7b1e3a;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(123, 30, 58, 0.1);
            transform: translateY(-2px);
        }

        /* Submit Button */
        .verify-btn {
            width: 100%;
            height: 54px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #7b1e3a 0%, #9c284e 100%);
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(123, 30, 58, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .verify-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(123, 30, 58, 0.3);
            filter: brightness(1.08);
        }

        .verify-btn:active {
            transform: translateY(0);
        }

        /* Resend Section */
        .resend {
            text-align: center;
            margin-top: 25px;
            color: #64748b;
            font-size: 14.5px;
        }

        .resend a {
            color: #7b1e3a;
            text-decoration: none;
            font-weight: 600;
            margin-left: 4px;
            transition: color 0.2s ease;
        }

        .resend a:hover {
            color: #b83a64;
            text-decoration: underline;
        }

        /* ─── RESPONSIVE STYLING ────────────────────────────── */
        @media (max-width: 991px) {
            html, body {
                height: auto;
                overflow: auto;
            }

            .otp-container {
                padding: 40px 15px;
            }

            .otp-card {
                flex-direction: column;
                height: auto;
                max-width: 550px;
            }

            .row-container {
                flex-direction: column;
            }

            .left-panel, .right-panel {
                width: 100%;
                padding: 40px 30px;
            }

            .left-panel {
                gap: 40px;
            }

            .left-panel-content h1 {
                font-size: 32px;
            }
        }

        @media (max-width: 480px) {
            .otp-inputs {
                gap: 6px;
            }

            .otp-inputs input {
                width: 42px;
                height: 48px;
                font-size: 18px;
                border-radius: 10px;
            }

            .left-panel, .right-panel {
                padding: 35px 20px;
            }
        }
    </style>
</head>

<body>

    <%- include('./partials/Nav') %>

    <div class="otp-container">
        <div class="otp-card">
            <div class="row-container">

                <!-- LEFT PANEL (Branding) -->
                <div class="left-panel">
                    <div class="left-panel-content">
                        <h1>Verify Your<br>Account 📚</h1>
                        <p>
                            Secure your library account with email verification and continue your reading journey seamlessly on LibFlow.
                        </p>
                    </div>

                    <div class="quote-box">
                        <h5>📖 Daily Quote</h5>
                        <p>“Books are uniquely portable magic.”</p>
                    </div>
                </div>

                <!-- RIGHT PANEL (OTP Input Form) -->
                <div class="right-panel">
                    <div class="otp-form">
                        <h2>OTP Verification</h2>
                        <p>Enter the 6-digit OTP sent to your registered email address.</p>

                        <!-- OTP Submission Form -->
                        <form action="/auth/api/verify-otp" method="POST" id="otpForm">
                            <div class="otp-inputs">
                                <input type="text" pattern="[0-9]*" inputmode="numeric" maxlength="1" name="otp1" autocomplete="one-time-code" required>
                                <input type="text" pattern="[0-9]*" inputmode="numeric" maxlength="1" name="otp2" required>
                                <input type="text" pattern="[0-9]*" inputmode="numeric" maxlength="1" name="otp3" required>
                                <input type="text" pattern="[0-9]*" inputmode="numeric" maxlength="1" name="otp4" required>
                                <input type="text" pattern="[0-9]*" inputmode="numeric" maxlength="1" name="otp5" required>
                                <input type="text" pattern="[0-9]*" inputmode="numeric" maxlength="1" name="otp6" required>
                            </div>

                            <button type="submit" class="verify-btn">
                                <span>Verify OTP</span>
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </button>
                        </form>

                        <div class="resend">
                            Didn't receive OTP? 
                            <a href="/resend-otp">Resend OTP</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <%- include('./partials/Scripts') %>

    <!-- ─── JAVASCRIPT FOR EXCELLENT USER EXPERIENCE ─────────── -->
    <script>
        const inputs = document.querySelectorAll(".otp-inputs input");
        const form = document.getElementById("otpForm");

        // Focus the first input box on load
        window.addEventListener("load", () => {
            if (inputs[0]) inputs[0].focus();
        });

        inputs.forEach((input, index) => {
            // Numeric validation & auto-navigation
            input.addEventListener("input", (e) => {
                const value = e.target.value;
                
                // Allow only numbers
                if (!/^[0-9]$/.test(value)) {
                    input.value = "";
                    return;
                }

                // Move focus forward
                if (value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });

            // Handle backspace, arrow keys
            input.addEventListener("keydown", (e) => {
                if (e.key === "Backspace") {
                    if (input.value === "" && index > 0) {
                        inputs[index - 1].value = "";
                        inputs[index - 1].focus();
                    } else {
                        input.value = "";
                    }
                    e.preventDefault();
                } else if (e.key === "ArrowLeft" && index > 0) {
                    inputs[index - 1].focus();
                } else if (e.key === "ArrowRight" && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });

            // Paste Support (Auto-fills all inputs)
            input.addEventListener("paste", (e) => {
                e.preventDefault();
                const pasteData = (e.clipboardData || window.clipboardData).getData("text");
                const numbersOnly = pasteData.replace(/[^0-9]/g, "").slice(0, 6);

                if (numbersOnly.length > 0) {
                    numbersOnly.split("").forEach((char, i) => {
                        if (inputs[i]) {
                            inputs[i].value = char;
                            if (inputs[i + 1]) inputs[i + 1].focus();
                        }
                    });
                    
                    // Focus final input or submit if fully filled
                    if (numbersOnly.length === 6) {
                        inputs[5].focus();
                    }
                }
            });
        });
    </script>
</body>
</html>
