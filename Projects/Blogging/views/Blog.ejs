<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title><%= blog.title %></title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>

<body class="blog-body">

    <%- include('./partials/Nav') %>

    <!-- Main Blog Wrapper -->
    <main class="blog-wrapper">

        <!-- Header -->
        <section class="blog-header">

            <div class="container">

                <!-- Category -->
                <div class="blog-category">
                    BLOG ARTICLE
                </div>

                <!-- Title -->
                <h1 class="blog-title">
                    <%= blog.title %>
                </h1>

                <!-- Meta -->
                <div class="blog-meta">

                    <div class="author-wrapper">

                        <div class="author-avatar">
                            <%= blog.createdBy?.name?.charAt(0).toUpperCase() || "A" %>
                        </div>

                        <div>

                            <div class="author-name">
                                <%= blog.createdBy?.fullName || "Admin" %>
                            </div>

                            <div class="publish-date">
                                Published on <%= new Date(blog.createdAt).toLocaleString('en-US', { 
                                    year: 'numeric', 
                                    month: 'short', 
                                    day: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit',
                                }) %>
                            </div>

                        </div>

                    </div>

                    <div class="reading-time">
                        5 min read
                    </div>

                </div>

            </div>

        </section>

        <!-- Cover Image -->
        <section class="container">

            <div class="cover-image-wrapper">

                <img 
                    src="<%= blog.coverImageURL %>" 
                    alt="<%= blog.title %>"
                    class="cover-image"
                >

            </div>

        </section>

        <!-- Blog Content -->
        <section class="blog-content-section">

            <div class="container">

                <div class="row justify-content-center">

                    <div class="col-lg-10 col-xl-9">

                        <article class="blog-content">

                            <p>
                                <%= blog.body %>
                            </p>

                        </article>

                    </div>

                </div>

            </div>

        </section>

    </main>

    <%- include('./partials/scripts') %>

</body>
</html>

<style>

    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
    }

    body.blog-body{
        background:#ffffff;
        color:#111827;
        font-family:'Inter',sans-serif;
        -webkit-font-smoothing:antialiased;
    }

    /* WRAPPER */

    .blog-wrapper{
        padding-bottom:5rem;
    }

    /* HEADER */

    .blog-header{
        padding-top:3rem;
        padding-bottom:1.5rem;
    }

    .blog-category{
        display:inline-flex;
        align-items:center;
        background:#eff6ff;
        color:#2563eb;
        font-size:0.78rem;
        font-weight:700;
        letter-spacing:1px;
        padding:0.55rem 1rem;
        border-radius:50px;
        margin-bottom:1.5rem;
    }

    .blog-title{
        font-size:4rem;
        line-height:1.08;
        font-weight:800;
        letter-spacing:-2px;
        color:#0f172a;
        max-width:950px;
    }

    /* META */

    .blog-meta{
        margin-top:2rem;
        display:flex;
        justify-content:space-between;
        align-items:center;
        flex-wrap:wrap;
        gap:1rem;
        border-top:1px solid #e5e7eb;
        padding-top:1.4rem;
    }

    .author-wrapper{
        display:flex;
        align-items:center;
        gap:1rem;
    }

    .author-avatar{
        width:50px;
        height:50px;
        border-radius:50%;
        background:linear-gradient(135deg,#2563eb,#4f46e5);
        display:flex;
        align-items:center;
        justify-content:center;
        color:white;
        font-weight:700;
        font-size:1rem;
    }

    .author-name{
        font-size:1rem;
        font-weight:700;
        color:#111827;
    }

    .publish-date{
        margin-top:3px;
        color:#6b7280;
        font-size:0.92rem;
    }

    .reading-time{
        color:#6b7280;
        font-size:0.95rem;
        font-weight:500;
    }

    /* IMAGE */

    .cover-image-wrapper{
        margin-top:1rem;
        overflow:hidden;
        border-radius:16px;
        max-width:900px;
        margin-left:auto;
        margin-right:auto;
    }

    .cover-image{
        width:100%;
        height:auto;
        max-height:500px;
        object-fit:contain;
        border-radius:16px;
        transition:transform 0.4s ease;
    }

    .cover-image:hover{
        transform:scale(1.01);
    }

    /* CONTENT */

    .blog-content-section{
        padding-top:3rem;
    }

    .blog-content{
        width:100%;
        font-size:1.15rem;
        line-height:2.2;
        color:#374151;
        font-weight:400;
    }

    .blog-content p{
        white-space:pre-line;
        text-align:justify;
        margin-bottom:1.5rem;
        letter-spacing:0.3px;
        word-spacing:2px;
    }

    /* RESPONSIVE */

    @media(max-width:992px){

        .blog-title{
            font-size:2.8rem;
            line-height:1.15;
        }

        .cover-image{
            height:260px;
        }

    }

    @media(max-width:768px){

        .blog-header{
            padding-top:2rem;
        }

        .blog-title{
            font-size:2rem;
            line-height:1.25;
            letter-spacing:-1px;
        }

        .blog-meta{
            align-items:flex-start;
        }

        .cover-image{
            height:220px;
            border-radius:12px;
        }

        .cover-image-wrapper{
            border-radius:12px;
        }

        .blog-content{
            font-size:1rem;
            line-height:2;
        }

        .author-avatar{
            width:44px;
            height:44px;
            font-size:0.95rem;
        }

    }

</style>