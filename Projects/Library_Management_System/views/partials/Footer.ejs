<style>
    /* ─── FOOTER STYLES ────────────────────────────────────── */
    .main-footer {
        background: #0f172a;
        color: #94a3b8;
        font-family: 'Poppins', sans-serif;
        padding: 80px 40px 30px;
        position: relative;
        overflow: hidden;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    /* Subtle background glow effects */
    .main-footer::before {
        content: '';
        position: absolute;
        top: -150px;
        left: -150px;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, rgba(99, 102, 241, 0) 70%);
        pointer-events: none;
    }

    .main-footer::after {
        content: '';
        position: absolute;
        bottom: -150px;
        right: -150px;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(20, 184, 166, 0.12) 0%, rgba(20, 184, 166, 0) 70%);
        pointer-events: none;
    }

    .footer-container {
        max-width: 1300px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
        gap: 50px;
        margin-bottom: 60px;
    }

    .footer-column h3 {
        color: #ffffff;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 25px;
        position: relative;
        display: inline-block;
    }

    .footer-column h3::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: -8px;
        width: 35px;
        height: 3px;
        background: linear-gradient(90deg, #6366f1, #14b8a6);
        border-radius: 2px;
    }

    /* Brand Column */
    .footer-brand-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #ffffff;
        font-size: 24px;
        font-weight: 800;
        text-decoration: none;
        margin-bottom: 20px;
    }

    .footer-brand-logo span {
        background: linear-gradient(90deg, #818cf8, #34d399);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .footer-brand p {
        font-size: 14.5px;
        line-height: 1.7;
        margin-bottom: 25px;
    }

    .footer-socials {
        display: flex;
        gap: 12px;
    }

    .social-btn {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .social-btn svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
    }

    .social-btn:hover {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #ffffff;
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
        border-color: transparent;
    }

    /* Links Columns */
    .footer-links-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-links-list li {
        margin-bottom: 14px;
    }

    .footer-links-list a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 14.5px;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .footer-links-list a::before {
        content: '→';
        opacity: 0;
        transform: translateX(-10px);
        transition: all 0.2s ease;
        color: #14b8a6;
    }

    .footer-links-list a:hover {
        color: #ffffff;
        padding-left: 5px;
    }

    .footer-links-list a:hover::before {
        opacity: 1;
        transform: translateX(0);
    }

    /* Newsletter Column */
    .footer-newsletter p {
        font-size: 14.5px;
        line-height: 1.7;
        margin-bottom: 20px;
    }

    .footer-contact p {
        font-size: 14.5px;
        line-height: 1.6;
        margin-bottom: 12px;
    }

    .footer-contact ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-contact li {
        font-size: 14px;
        color: #94a3b8;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Bottom Section */
    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding-top: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
    }

    .footer-copyright {
        font-size: 13.5px;
    }

    .footer-bottom-links {
        display: flex;
        gap: 25px;
    }

    .footer-bottom-links a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 13.5px;
        transition: color 0.2s ease;
    }

    .footer-bottom-links a:hover {
        color: #ffffff;
    }

    /* Responsiveness */
    @media (max-width: 1024px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }
    }

    @media (max-width: 640px) {
        .main-footer {
            padding: 60px 20px 30px;
        }
        .footer-grid {
            grid-template-columns: 1fr;
            gap: 35px;
        }
        .footer-bottom {
            flex-direction: column;
            text-align: center;
        }
        .footer-bottom-links {
            justify-content: center;
        }
    }
</style>

