<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/Head') %>
    <title>Reset Password - Library Management System</title>

    <style>
        * {
            margin: 0;
            padding: 0;
        }

        html, body {
            background: #f7f1f3;
            font-family: 'Poppins', sans-serif;
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .reset-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            min-height: 0;
        }

        .reset-card {
            width: 100%;
            max-width: 1000px;
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
            display: flex;
            height: 100%;
        }

        .reset-card .row {
            width: 100%;
            height: 100%;
        }

        .left-panel {
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.55)), url('/resgiter.jpg') no-repeat center center;
            background-size: cover;
            color: white;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            height: 100%;
            overflow: hidden;
        }

        .left-panel h1 {
            font-size: 48px;
            font-weight: 700;
            line-height: 65px;
            margin-bottom: 20px;
        }

        .left-panel p {
            color: #f5d6df;
            line-height: 30px;
            font-size: 16px;
        }

        .info-box {
            margin-top: 35px;
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 16px;
            border-left: 4px solid #fff;
        }

        .info-box h5 {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .right-panel {
            padding: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            overflow-y: auto;
        }

        .reset-form {
            width: 100%;
            max-width: 450px;
        }

        .reset-form h2 {
            color: #7b1e3a;
            font-weight: 700;
            margin-bottom: 10px;
            font-size: 32px;
        }

        .reset-form .subtitle {
            color: #888;
            margin-bottom: 35px;
            line-height: 28px;
            font-size: 15px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            color: #333;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 15px;
        }

        .form-group input {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 15px;
            transition: 0.3s;
            font-family: 'Poppins', sans-serif;
        }

        .form-group input:focus {
            outline: none;
            border-color: #7b1e3a;
            box-shadow: 0 0 0 3px rgba(123, 30, 58, 0.1);
        }

        .error-message {
            color: #dc3545;
            font-size: 14px;
            margin-bottom: 20px;
            padding: 12px 15px;
            background: #f8d7da;
            border-radius: 8px;
            border-left: 4px solid #dc3545;
        }

        .password-requirements {
            background: #f0f4f8;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 25px;
            font-size: 13px;
            color: #475569;
        }

        .requirement {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
        }

        .requirement:last-child {
            margin-bottom: 0;
        }

        .requirement.valid {
            color: #10b981;
        }

        .requirement.invalid {
            color: #ef4444;
        }

        .requirement-icon {
            width: 16px;
            height: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .reset-btn {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #7b1e3a, #a8325c);
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .reset-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(123, 30, 58, 0.3);
        }

        .reset-btn:active {
            transform: translateY(0);
        }

        .back-link {
            text-align: center;
            margin-top: 20px;
            color: #888;
        }

        .back-link a {
            color: #7b1e3a;
            text-decoration: none;
            font-weight: 600;
        }

        .back-link a:hover {
            text-decoration: underline;
        }

        @media (max-width: 991px) {
            html, body {
                height: auto;
                overflow: auto;
            }

            .reset-container {
                height: auto;
                padding: 40px 15px;
            }

            .reset-card {
                height: auto;
                border-radius: 20px;
            }

            .reset-card .row {
                height: auto;
            }

            .left-panel {
                height: auto;
                padding: 40px;
            }

            .left-panel h1 {
                font-size: 36px;
                line-height: 50px;
            }

            .right-panel {
                height: auto;
                padding: 40px 25px;
            }
        }

        @media (max-width: 576px) {
            .reset-container {
                padding: 15px;
            }

            .left-panel {
                padding: 30px;
                text-align: center;
            }

            .left-panel h1 {
                font-size: 28px;
                line-height: 40px;
            }

            .left-panel p {
                font-size: 14px;
            }

            .right-panel {
                padding: 30px 20px;
            }

            .reset-form h2 {
                font-size: 26px;
            }

            .form-group input {
                padding: 12px 14px;
                font-size: 14px;
            }

            .password-requirements {
                font-size: 12px;
                padding: 12px;
            }
        }
    </style>
</head>

<body>
    <%- include('./partials/Nav') %>

    <div class="reset-container">
        <div class="reset-card">
            <div class="row g-0">
                <!-- LEFT PANEL -->
                <div class="col-lg-6">
                    <div class="left-panel">
                        <h1>
                            Create New Password 🔐
                        </h1>

                        <div class="info-box">
                            <h5>🛡️ Secure Your Account</h5>
                            <p class="mb-0">
                                Create a strong password to protect your library account. Use a mix of uppercase, lowercase, numbers, and special characters for maximum security.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- RIGHT PANEL -->
                <div class="col-lg-6">
                    <div class="right-panel">
                        <div class="reset-form">
                            <h2>Reset Password</h2>
                            <p class="subtitle">
                                Enter your new password below
                            </p>

                            <% if (locals.error) { %>
                                <div class="error-message">
                                    <%= error %>
                                </div>
                            <% } %>

                            <div class="password-requirements">
                                <div class="requirement" id="req-length">
                                    <span class="requirement-icon">✓</span>
                                    <span>At least 6 characters</span>
                                </div>
                                <div class="requirement" id="req-uppercase">
                                    <span class="requirement-icon">○</span>
                                    <span>Contains uppercase letters (A-Z)</span>
                                </div>
                                <div class="requirement" id="req-number">
                                    <span class="requirement-icon">○</span>
                                    <span>Contains numbers (0-9)</span>
                                </div>
                            </div>

                            <form action="/auth/api/reset-password" method="POST">
                                <input type="hidden" name="email" value="<%= email %>">

                                <div class="form-group">
                                    <label for="newPassword">New Password</label>
                                    <input 
                                        type="password" 
                                        id="newPassword"
                                        name="newPassword" 
                                        placeholder="Enter new password"
                                        required
                                        onInput="validatePassword()">
                                </div>

                                <div class="form-group">
                                    <label for="confirmPassword">Confirm Password</label>
                                    <input 
                                        type="password" 
                                        id="confirmPassword"
                                        name="confirmPassword" 
                                        placeholder="Confirm your password"
                                        required>
                                </div>

                                <button type="submit" class="reset-btn">
                                    Reset Password
                                </button>
                            </form>

                            <div class="back-link">
                                Remember your password?
                                <a href="/login">
                                    Log in here
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('./partials/Scripts') %>

    <script>
        function validatePassword() {
            const password = document.getElementById('newPassword').value;
            
            // Check length
            const lengthReq = document.getElementById('req-length');
            if (password.length >= 6) {
                lengthReq.classList.add('valid');
                lengthReq.classList.remove('invalid');
                lengthReq.querySelector('.requirement-icon').textContent = '✓';
            } else {
                lengthReq.classList.remove('valid');
                lengthReq.classList.add('invalid');
                lengthReq.querySelector('.requirement-icon').textContent = '✗';
            }
            
            // Check uppercase
            const uppercaseReq = document.getElementById('req-uppercase');
            if (/[A-Z]/.test(password)) {
                uppercaseReq.classList.add('valid');
                uppercaseReq.classList.remove('invalid');
                uppercaseReq.querySelector('.requirement-icon').textContent = '✓';
            } else {
                uppercaseReq.classList.remove('valid');
                uppercaseReq.classList.add('invalid');
                uppercaseReq.querySelector('.requirement-icon').textContent = '○';
            }
            
            // Check number
            const numberReq = document.getElementById('req-number');
            if (/[0-9]/.test(password)) {
                numberReq.classList.add('valid');
                numberReq.classList.remove('invalid');
                numberReq.querySelector('.requirement-icon').textContent = '✓';
            } else {
                numberReq.classList.remove('valid');
                numberReq.classList.add('invalid');
                numberReq.querySelector('.requirement-icon').textContent = '○';
            }
        }
    </script>
</body>
</html>