                <p style="margin-bottom:14px;"><strong>Total Stocked:</strong> <span id="detailCopies">-</span></p>
                <p style="margin-bottom: 20px;"><strong>Synopsis:</strong> <span id="detailDesc" style="display:block; margin-top:6px; color:var(--text-muted); font-style:italic; line-height:1.6;">-</span></p>
            </div>
            
            <div class="modal-actions">
                <button class="btn-submit" style="padding: 10px 24px;" onclick="closeDetailsModal()">Close Details</button>
            </div>
        </div>
    </div>

    <!-- ─── INTERACTIVE CLIENT SIDE CONTROLS ───────────────── -->
    <script>
        // Tab switching controller
        function switchTab(tabName, menuItem) {
            // Hide all tab panels
            document.querySelectorAll('.tab-panel').forEach(panel => {
                panel.classList.remove('active');
            });
            
            // Remove active state from menu items
            document.querySelectorAll('.menu-item').forEach(item => {
                item.classList.remove('active');
            });
            
            // Activate target tab panel
            const targetPanel = document.getElementById(tabName + 'Tab');
            if (targetPanel) {
                targetPanel.classList.add('active');
            }
            
            // Activate selected menu item
            menuItem.classList.add('active');

            // Update Header title dynamically
            const headerTitle = document.getElementById('headerTitle');
            if (tabName === 'overview') headerTitle.innerText = "Dashboard Overview";
            else if (tabName === 'add-book') headerTitle.innerText = "Add New Book Catalog Entry";
            else if (tabName === 'manage-books') headerTitle.innerText = "Manage Library Book Stock";
        }

        // Live Table Search Filter
        function filterTable() {
            const query = document.getElementById("tableSearch").value.toLowerCase();
            const rows = document.querySelectorAll("#booksTable tbody .book-row");
            let count = 0;

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(query)) {
                    row.style.display = "";
                    count++;
                } else {
                    row.style.display = "none";
                }
            });

            document.getElementById("visibleCount").innerText = count;
        }

        // Delete Modal Handler
        function triggerDeleteModal(bookTitle) {
            document.getElementById("deleteTargetBook").innerText = `"${bookTitle}"`;
            document.getElementById("deleteInputTitle").value = bookTitle;
            document.getElementById("deleteModal").classList.add("active");
        }

        function closeDeleteModal() {
            document.getElementById("deleteModal").classList.remove("active");
        }

        // Details Modal Handler
        function viewBookDetails(title, author, category, isbn, copies, description) {
            document.getElementById("detailTitle").innerText = title;
            document.getElementById("detailAuthor").innerText = author;
            document.getElementById("detailCategory").innerText = category;
            document.getElementById("detailIsbn").innerText = isbn;
            document.getElementById("detailCopies").innerText = copies + ' copies';
            document.getElementById("detailDesc").innerText = description || 'No synopsis provided.';
            
            document.getElementById("detailsModal").classList.add("active");
        }

        function closeDetailsModal() {
            document.getElementById("detailsModal").classList.remove("active");
        }

        // ─── DRAG & DROP + CLICK-TO-BROWSE FILE UPLOAD ──────────
        (function() {
            const dropZone = document.getElementById('dropZone');
            const fileInput = document.getElementById('fileInput');
            const uploadPreview = document.getElementById('uploadPreview');
            const previewImg = document.getElementById('previewImg');
            const btnRemovePreview = document.getElementById('btnRemovePreview');

            if (!dropZone || !fileInput) return;

            // 1) Click anywhere on the drop zone → open native file picker
            dropZone.addEventListener('click', function(e) {
                // Don't re-trigger if clicking the remove button
                if (e.target === btnRemovePreview || e.target.closest('.btn-remove-preview')) return;
                fileInput.click();
            });

            // 2) When a file is selected via the file picker
            fileInput.addEventListener('change', function() {
                if (fileInput.files && fileInput.files[0]) {
                    showPreview(fileInput.files[0]);
                }
            });

            // 3) Drag & Drop events
            ['dragenter', 'dragover'].forEach(eventName => {
                dropZone.addEventListener(eventName, function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    dropZone.classList.add('dragover');
                });
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    dropZone.classList.remove('dragover');
                });
            });

            dropZone.addEventListener('drop', function(e) {
                const files = e.dataTransfer.files;
                if (files && files[0]) {
                    // Validate it's an image
                    if (!files[0].type.startsWith('image/')) {
                        alert('Please upload an image file (PNG, JPG, JPEG, WEBP, or AVIF).');
                        return;
                    }
                    // Validate size (max 5MB)
                    if (files[0].size > 5 * 1024 * 1024) {
                        alert('File size exceeds 5MB. Please choose a smaller image.');
                        return;
                    }
                    // Assign the dropped file to the hidden file input
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(files[0]);
                    fileInput.files = dataTransfer.files;
                    showPreview(files[0]);
                }
            });

            // 4) Show the image preview
            function showPreview(file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    uploadPreview.style.display = 'flex';
                };
                reader.readAsDataURL(file);
            }

            // 5) Remove preview and clear the file input
            btnRemovePreview.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                previewImg.src = '';
                uploadPreview.style.display = 'none';
                fileInput.value = '';
            });
        })();
    </script>

    <!-- ─── TOAST NOTIFICATION SYSTEM ─────────────────────── -->
    <style>
        .toast-container {
            position: fixed;
            top: 28px;
            right: 28px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .toast {
            display: flex;
            align-items: center;
            gap: 14px;
            background: #0f172a;
            color: #f1f5f9;
            padding: 16px 24px;
            border-radius: 14px;
            font-family: 'Poppins', sans-serif;
            font-size: 14px;
            font-weight: 500;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.25);
            animation: toastSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            min-width: 320px;
            max-width: 480px;
            border-left: 4px solid #7b1e3a; /* LibFlow signature maroon */
            backdrop-filter: blur(10px);
        }
        .toast.toast-hide {
            animation: toastSlideOut 0.35s ease forwards;
        }
        .toast-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(123, 30, 58, 0.15); /* LibFlow signature maroon light trans */
            color: #7b1e3a; /* LibFlow signature maroon */
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .toast-icon svg {
            width: 18px;
            height: 18px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.2;
        }
        .toast-msg {
            flex: 1;
            line-height: 1.4;
        }
        .toast-close {
            background: none;
            border: none;
            color: #64748b;
            cursor: pointer;
            font-size: 18px;
            padding: 4px;
            line-height: 1;
            transition: color 0.2s;
        }
        .toast-close:hover {
            color: #f1f5f9;
        }
        @keyframes toastSlideIn {
            from { transform: translateX(120%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        @keyframes toastSlideOut {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(120%); opacity: 0; }
        }
    </style>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        (function() {
            const params = new URLSearchParams(window.location.search);
            const message = params.get('message');
            if (!message) return;

            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `
                <div class="toast-icon">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                </div>
                <span class="toast-msg">${message}</span>
                <button class="toast-close" onclick="this.parentElement.classList.add('toast-hide'); setTimeout(()=>this.parentElement.remove(),350);">&times;</button>
            `;
            container.appendChild(toast);

            setTimeout(() => {
                toast.classList.add('toast-hide');
                setTimeout(() => toast.remove(), 350);
            }, 4000);

            window.history.replaceState({}, document.title, window.location.pathname);
        })();
    </script>
</body>
</html>
