<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Modern URL Shortener</title>

    <!-- GOOGLE FONT -->

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family:'Inter',sans-serif;

            height:100vh;
            overflow:hidden;

            color:white;

            background:
            radial-gradient(circle at top left,#312e81 0%,transparent 30%),
            radial-gradient(circle at bottom right,#7e22ce 0%,transparent 30%),
            linear-gradient(135deg,#0f172a,#111827,#1e1b4b);
        }

        /* BACKGROUND BLOBS */

        .blob{
            position:absolute;
            border-radius:50%;
            filter:blur(100px);
            opacity:0.25;
            animation:float 10s infinite ease-in-out;
            z-index:-1;
        }

        .blob1{
            width:300px;
            height:300px;
            background:#8b5cf6;
            top:10%;
            left:5%;
        }

        .blob2{
            width:250px;
            height:250px;
            background:#ec4899;
            bottom:10%;
            right:5%;
        }

        .blob3{
            width:220px;
            height:220px;
            background:#06b6d4;
            top:50%;
            left:45%;
        }

        @keyframes float{

            0%{
                transform:translateY(0px);
            }

            50%{
                transform:translateY(-30px);
            }

            100%{
                transform:translateY(0px);
            }

        }

        /* NAVBAR */

        .navbar{
            width:100%;
            height:80px;

            padding:0 50px;

            position:fixed;
            top:0;

            display:flex;
            justify-content:space-between;
            align-items:center;

            background:rgba(15,23,42,0.4);

            backdrop-filter:blur(12px);

            border-bottom:
            1px solid rgba(255,255,255,0.08);

            z-index:1000;
        }

        .nav-logo{
            font-size:28px;
            font-weight:800;

            background:linear-gradient(
                135deg,
                #8b5cf6,
                #ec4899
            );

            -webkit-background-clip:text;
            -webkit-text-fill-color:transparent;
        }

        .nav-btn{
            text-decoration:none;

            padding:12px 22px;

            border-radius:14px;

            background:linear-gradient(
                135deg,
                #8b5cf6,
                #ec4899
            );

            color:white;
            font-size:14px;
            font-weight:600;

            transition:0.3s;
        }

        .nav-btn:hover{
            transform:translateY(-2px);

            box-shadow:
            0 10px 25px rgba(139,92,246,0.35);
        }

        /* MAIN */

        .main{
            width:100%;
            height:100vh;

            display:flex;
            justify-content:center;
            align-items:center;

            padding-top:80px;
        }

        .container{
            width:100%;
            max-width:650px;

            padding:35px;

            border-radius:30px;

            background:rgba(255,255,255,0.08);

            backdrop-filter:blur(18px);

            border:1px solid rgba(255,255,255,0.1);

            box-shadow:
            0 10px 40px rgba(0,0,0,0.4),
            inset 0 1px 1px rgba(255,255,255,0.08);

            position:relative;
            overflow:hidden;

            animation:fadeUp 0.8s ease;
        }

        @keyframes fadeUp{

            from{
                opacity:0;
                transform:translateY(30px);
            }

            to{
                opacity:1;
                transform:translateY(0);
            }

        }

        .container::before{
            content:"";
            position:absolute;

            width:250px;
            height:250px;

            background:#8b5cf6;

            border-radius:50%;

            top:-120px;
            right:-100px;

            opacity:0.2;
            filter:blur(40px);
        }

        /* LOGO */

        .logo{
            width:85px;
            height:85px;

            margin:auto;
            margin-bottom:24px;

            border-radius:24px;

            background:linear-gradient(
                135deg,
                #8b5cf6,
                #ec4899
            );

            display:flex;
            justify-content:center;
            align-items:center;

            font-size:34px;

            box-shadow:
            0 10px 30px rgba(139,92,246,0.5);
        }

        /* TITLE */

        h1{
            text-align:center;
            font-size:42px;
            font-weight:800;
            line-height:1.1;

            margin-bottom:12px;
        }

        .subtitle{
            text-align:center;
            color:#cbd5e1;
            line-height:1.7;

            margin-bottom:30px;

            font-size:15px;
        }

        /* FORM */

        form{
            display:flex;
            flex-direction:column;
            gap:20px;
        }

        .input-group{
            display:flex;
            flex-direction:column;
            gap:10px;
        }

        label{
            font-size:14px;
            font-weight:500;
            color:#e5e7eb;
        }

        input{
            width:100%;
            padding:18px;

            border-radius:16px;

            border:1px solid rgba(255,255,255,0.1);

            background:rgba(255,255,255,0.07);

            color:white;
            font-size:15px;

            outline:none;
            transition:0.3s;
        }

        input:focus{
            border-color:#8b5cf6;

            box-shadow:
            0 0 0 4px rgba(139,92,246,0.2);
        }

        input::placeholder{
            color:#94a3b8;
        }

        /* BUTTON */

        .submit-btn{
            width:100%;
            padding:18px;

            border:none;
            border-radius:16px;

            background:linear-gradient(
                135deg,
                #8b5cf6,
                #ec4899
            );

            color:white;

            font-size:16px;
            font-weight:700;

            cursor:pointer;

            position:relative;
            overflow:hidden;

            transition:0.35s ease;

            box-shadow:
            0 10px 25px rgba(139,92,246,0.35);
        }

        .submit-btn::before{
            content:"";
            position:absolute;

            top:0;
            left:-100%;

            width:100%;
            height:100%;

            background:rgba(255,255,255,0.2);

            transition:0.5s;
        }

        .submit-btn:hover::before{
            left:100%;
        }

        .submit-btn:hover{
            transform:translateY(-3px) scale(1.01);

            box-shadow:
            0 18px 35px rgba(236,72,153,0.4);
        }

        /* RESULT */

        .result{
            margin-top:28px;

            padding:22px;

            border-radius:22px;

            background:rgba(255,255,255,0.06);

            border:1px solid rgba(255,255,255,0.08);
        }

        .result-title{
            font-size:14px;
            color:#cbd5e1;
            margin-bottom:15px;
        }

        .short-url{
            display:flex;
            justify-content:space-between;
            align-items:center;

            gap:15px;

            padding:18px;

            border-radius:16px;

            background:rgba(255,255,255,0.08);

            transition:0.3s;

            word-break:break-all;
        }

        .short-url:hover{
            background:rgba(255,255,255,0.12);
            transform:scale(1.01);
        }

        .short-link{
            color:white;
            font-weight:600;
        }

        .action-buttons{
            display:flex;
            gap:10px;
        }

        .visit-btn{
            text-decoration:none;

            padding:10px 15px;

            border-radius:12px;

            background:#8b5cf6;

            color:white;
            font-size:14px;
            font-weight:600;
        }

        .copy-btn{
            width:auto;

            padding:10px 15px;

            border:none;
            border-radius:12px;

            background:#06b6d4;

            color:white;
            font-size:14px;
            font-weight:600;

            cursor:pointer;
        }

        /* STATS */

        .stats{
            margin-top:20px;

            display:flex;
            gap:15px;
        }

        .stat-card{
            flex:1;

            padding:18px;

            border-radius:18px;

            background:rgba(255,255,255,0.06);

            border:1px solid rgba(255,255,255,0.08);

            text-align:center;
        }

        .stat-card h3{
            font-size:28px;
            margin-bottom:6px;
        }

        .stat-card p{
            font-size:14px;
            color:#cbd5e1;
        }

        /* FOOTER */

        .footer{
            margin-top:20px;
            text-align:center;

            font-size:13px;
            color:#94a3b8;
        }

        #logout{
            padding-top: 1rem; 
            padding-bottom: 1rem;
            padding-right: 2rem;
            padding-left: 2rem;
            font-weight: bold; 
            font-size: 15px; 
            color: white; 
            background-color: red; 
            border: none;
            border-radius: 10px;
            text-align: center;
        }

        /* RESPONSIVE */

        @media(max-width:768px){

            body{
                overflow:auto;
            }

            .navbar{
                padding:0 20px;
            }

            .main{
                padding:100px 20px 20px;
                height:auto;
            }

            .container{
                padding:28px 20px;
            }

            h1{
                font-size:34px;
            }

            .short-url{
                flex-direction:column;
                align-items:flex-start;
            }

            .stats{
                flex-direction:column;
            }

        }

    </style>

</head>

<body>

    <!-- BLOBS -->

    <div class="blob blob1"></div>
    <div class="blob blob2"></div>
    <div class="blob blob3"></div>

    <!-- NAVBAR -->

    <nav class="navbar">

        <div class="nav-logo">
            URLify
        </div>

        <form action="/user/logout" method="GET">
            <button id="logout" type="submit">Logout</button>
        </form>

    </nav>

    <!-- MAIN -->

    <section class="main">

        <div class="container">

            <!-- LOGO -->

            <div class="logo">
                🔗
            </div>

            <!-- TITLE -->

            <h1>
                Shorten Your Long URLs
            </h1>

            <p class="subtitle">
                Transform lengthy links into clean,
                beautiful and shareable URLs within seconds.
            </p>

            <!-- FORM -->

            <form method="POST" action="/url">

                <div class="input-group">

                    <label>
                        Paste Your Long URL
                    </label>

                    <input
                        type="text"
                        name="url"
                        placeholder="https://example.com/very-long-url"
                        required
                    >

                </div>

                <button
                    type="submit"
                    class="submit-btn"
                >
                    Generate Short URL
                </button>

            </form>

            <!-- RESULT -->

            <% if(locals.id){ %>

                <div class="result">

                    <p class="result-title">
                        Your Shortened URL
                    </p>

                    <div class="short-url">

                        <span
                            class="short-link"
                            id="shortURL"
                        >
                            http://localhost:3000/url/<%= id %>
                        </span>

                        <div class="action-buttons">

                            <a
                                href="http://localhost:3000/url/<%= id %>"
                                target="_blank"
                                class="visit-btn"
                            >
                                Visit
                            </a>

                            <button
                                type="button"
                                class="copy-btn"
                                onclick="copyURL()"
                            >
                                Copy
                            </button>

                        </div>

                    </div>

                </div>

            <% } %>

            <!-- STATS -->

            <div class="stats">

                <div class="stat-card">
                    <h3>10K+</h3>
                    <p>URLs Shortened</p>
                </div>

                <div class="stat-card">
                    <h3>99.9%</h3>
                    <p>Fast Redirect</p>
                </div>

            </div>

            <!-- FOOTER -->

            <div class="footer">
                Built with Node.js, Express, MongoDB & EJS
            </div>

        </div>

    </section>

    <!-- SCRIPT -->

    <script>

        function copyURL(){

            const url =
            document.getElementById("shortURL").innerText;

            navigator.clipboard.writeText(url);

            alert("URL Copied Successfully!");

        }

    </script>

</body>

</html>